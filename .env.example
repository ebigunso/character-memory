QDRANT_CONNECTION_STRING="http://localhost:6334"
OXIGRAPH_PATH="./data/oxigraph"
# Embedded persistent Oxigraph is the application default. Set GRAPH_STORE_MODE="in_memory"
# only for tests, fixtures, or other explicitly ephemeral runs.
GRAPH_STORE_MODE="persistent"
OPENAI_API_KEY="YOUR_OPENAI_KEY"
EMBEDDING_MODEL="text-embedding-3-small"
